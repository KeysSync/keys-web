# ============================================================
# Keys · Web — variáveis de ambiente
# Copie este arquivo para .env.local e ajuste para a sua máquina.
# ============================================================

# URL base da API do Keys (sem barra no final).
# Local (padrão): http://localhost:8000
# Staging:        https://stage-api.imobkeys.com
# Produção:       (definir quando disponível)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Ambiente lógico ("local" | "staging" | "production").
# Usado apenas para exibir/log; não controla comportamento do Next.
NEXT_PUBLIC_APP_ENV=local
